<Window x:Class="XvTPilotEditor.Views.NewPilotDialogue"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:XvTPilotEditor.Views"
        mc:Ignorable="d"
        Title="Open a Pilot File" Height="375" Width="600">
    <StackPanel>
        <Label Content="Select an XvT Pilot File to Open" HorizontalAlignment="Left" Margin="10"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Label      Grid.Column="0" Content="File Path:" Margin="10,0,10,0"/>
            <TextBox    x:Name="PltFilePathTextBox" Grid.Column="1" Height="25"/>
            <Button     Grid.Column="2" Content="Browse..." Margin="10,0,10,0" Command="{Binding OpenPltCommand}"/>
        </Grid>
        <Label Content="" HorizontalAlignment="Center" Margin="5"/>
        <Label Content="Select a BoP Pilot File to Open" HorizontalAlignment="Left" Margin="10"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Label      Grid.Column="0" Content="File Path:" Margin="10,0,10,0"/>
            <TextBox    x:Name="Pl2FilePathTextBox" Grid.Column="1" Height="25"/>
            <Button     Grid.Column="2" Content="Browse..." Margin="10,0,10,0" Command="{Binding OpenPl2Command}"/>
        </Grid>
        <Label Content="" HorizontalAlignment="Center" Margin="5"/>
        <Grid HorizontalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>
            <Label      Grid.Column="0" Content="Pilot Name" Margin="10,0,10,0"/>
            <TextBox    x:Name="PilotNameTextBox" Grid.Column="1" Height="25"/>
        </Grid>
        <Label Content="" HorizontalAlignment="Center" Margin="5"/>
        <Button Content="Open Pilot" HorizontalAlignment="Center" Margin="10" Command="{Binding CreatePilotCommand}"/>
    </StackPanel>
</Window>
