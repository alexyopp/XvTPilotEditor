<UserControl x:Class="XvTPilotEditor.Views.PltDataView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:XvTPilotEditor.Views"
             xmlns:ctrl="clr-namespace:XvTPilotEditor.Views.Controls"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
        <StackPanel Orientation="Vertical" VerticalAlignment="Top">

            <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
                <ctrl:LabeledTextBox Label="Pilot Name:"
                    Value="{Binding PilotName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Metadata=""/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
                <ctrl:LabeledTextBox Label="Total Score:"
                    Value="{Binding TotalScore, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Metadata=""/>
            </StackPanel>
            

            <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
                <ctrl:LabeledTextBox Label="Player ID:"
                    Value="{Binding PlayerID, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Metadata=""/>
            </StackPanel>


            <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
                <ctrl:LabeledTextBox Label="Continued / Reflown Mission:"
                    Value="{Binding ContinuedOrReflownMission, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Metadata=""/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
                <ctrl:LabeledTextBox Label="Is Hosting:"
                    Value="{Binding IsHosting, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Metadata=""/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
                <ctrl:LabeledTextBox Label="Num Human Players In Mission:"
                    Value="{Binding NumHumanPlayersInMission, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Metadata=""/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
                <ctrl:LabeledTextBox Label="Front Fly Mode:"
                    Value="{Binding FrontFlyMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Metadata=""/>
            </StackPanel>

            <!-- Arrays as expanders (simple indexed list) -->
            <Expander Header="Unknown0x26" IsExpanded="False" Margin="0,6,0,6">
                <ItemsControl ItemsSource="{Binding Unknown0x26.Values}" AlternationCount="1000">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="25,4">
                                <TextBlock Width="40" Text="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}, StringFormat='[{0}]'}"/>
                                <TextBox Width="200" Margin="8,0,0,0" Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Expander>

            <Expander Header="Unknown0x166" IsExpanded="False" Margin="0,6,0,6">
                <ItemsControl ItemsSource="{Binding Unknown0x166.Values}" AlternationCount="1000">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="25,4">
                                <TextBlock Width="40" Text="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}, StringFormat='[{0}]'}"/>
                                <TextBox Width="200" Margin="8,0,0,0" Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Expander>

            <Expander Header="Unknown0x186" IsExpanded="False" Margin="0,6,0,6">
                <ItemsControl ItemsSource="{Binding Unknown0x186.Values}" AlternationCount="1000">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="25,4">
                                <TextBlock Width="40" Text="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}, StringFormat='[{0}]'}"/>
                                <TextBox Width="200" Margin="8,0,0,0" Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Expander>

            <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
                <ctrl:LabeledTextBox Label="Promo Points:"
                    Value="{Binding PromoPoints, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Metadata=""/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
                <ctrl:LabeledTextBox Label="Worse Promo Points:"
                    Value="{Binding WorsePromoPoints, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Metadata=""/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
                <ctrl:LabeledTextBox Label="Rank Adjustment Applied:"
                    Value="{Binding RankAdjustmentApplied, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Metadata=""/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
                <ctrl:LabeledTextBox Label="Percent To Next Rank:"
                    Value="{Binding PercentToNextRank, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Metadata=""/>
            </StackPanel>
            
            <ctrl:ExerciseMeleeCombatHeader/>

            <!-- TotalCategoryScore -->
            <ctrl:LabeledTripleTextBox
                Label="Total Category Score:"
                TextBox1Content="{Binding TotalCategoryScoreExercise, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                TextBox2Content="{Binding TotalCategoryScoreMelee, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                TextBox3Content="{Binding TotalCategoryScoreCombatEngagement, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- NumFlownNonSeries -->
            <ctrl:LabeledTripleTextBox
                Label="Num Flown Non Series:"
                TextBox1Content="{Binding NumFlownNonSeriesExercise, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                TextBox2Content="{Binding NumFlownNonSeriesMelee, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                TextBox3Content="{Binding NumFlownNonSeriesCombatEngagement, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- NumFlownSeries -->
            <ctrl:LabeledTripleTextBox
                Label="Num Flown Series:"
                TextBox1Content="{Binding NumFlownSeriesExercise, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                TextBox2Content="{Binding NumFlownSeriesMelee, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                TextBox3Content="{Binding NumFlownSeriesCombatEngagement, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- TotalKills -->
            <ctrl:LabeledTripleTextBox
                Label="Total Kills:"
                TextBox1Content="{Binding TotalKillsExercise, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                TextBox2Content="{Binding TotalKillsMelee, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                TextBox3Content="{Binding TotalKillsCombatEngagement, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- FriendlyKills -->
            <ctrl:LabeledTripleTextBox
                Label="Friendly Kills:"
                TextBox1Content="{Binding FriendlyKillsExercise, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                TextBox2Content="{Binding FriendlyKillsMelee, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                TextBox3Content="{Binding FriendlyKillsCombatEngagement, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- TODO: Fix display so that indices are only listed once on the left, and replaced by rating strings, remove extraneous Exercise/Melee/Combat labels, Shared Kills and Full Kills are integrated into KillTuples, and line up columns with the QuadBase layout; remove Expander once item filtering is in place  -->
            <!-- TotalFullKillsOnPlayerRating -->
            <Expander Header="Total Kills On Player Rating" IsExpanded="False" Margin="0,6,0,6">
                <StackPanel Margin="8" Orientation="Horizontal">
                    <TextBlock FontWeight="Bold" Text="Exercise" Margin="4,2"/>
                    <ItemsControl ItemsSource="{Binding TotalFullKillsOnPlayerRating.Exercise}" AlternationCount="1000">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="8,2">
                                    <TextBlock Width="40" Text="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}, StringFormat='[{0}]'}"/>
                                    <TextBox Width="200" Margin="8,0,0,0" Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock FontWeight="Bold" Text="Melee" Margin="4,8,4,2"/>
                    <ItemsControl ItemsSource="{Binding TotalFullKillsOnPlayerRating.Melee}" AlternationCount="1000">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="8,2">
                                    <TextBlock Width="40" Text="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}, StringFormat='[{0}]'}"/>
                                    <TextBox Width="200" Margin="8,0,0,0" Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock FontWeight="Bold" Text="Combat" Margin="4,8,4,2"/>
                    <ItemsControl ItemsSource="{Binding TotalFullKillsOnPlayerRating.Combat}" AlternationCount="1000">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="8,2">
                                    <TextBlock Width="40" Text="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}, StringFormat='[{0}]'}"/>
                                    <TextBox Width="200" Margin="8,0,0,0" Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Expander>

            <!-- TotalSharedKillsOnPlayerRating -->
            <Expander Header="Total Shared Kills On Player Rating" IsExpanded="False" Margin="0,6,0,6">
                <StackPanel Margin="8" Orientation="Horizontal">
                    <TextBlock FontWeight="Bold" Text="Exercise" Margin="4,2"/>
                    <ItemsControl ItemsSource="{Binding TotalSharedKillsOnPlayerRating.Exercise}" AlternationCount="1000">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="8,2">
                                    <TextBlock Width="40" Text="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}, StringFormat='[{0}]'}"/>
                                    <TextBox Width="200" Margin="8,0,0,0" Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock FontWeight="Bold" Text="Melee" Margin="4,8,4,2"/>
                    <ItemsControl ItemsSource="{Binding TotalSharedKillsOnPlayerRating.Melee}" AlternationCount="1000">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="8,2">
                                    <TextBlock Width="40" Text="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}, StringFormat='[{0}]'}"/>
                                    <TextBox Width="200" Margin="8,0,0,0" Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock FontWeight="Bold" Text="Combat" Margin="4,8,4,2"/>
                    <ItemsControl ItemsSource="{Binding TotalSharedKillsOnPlayerRating.Combat}" AlternationCount="1000">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="8,2">
                                    <TextBlock Width="40" Text="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}, StringFormat='[{0}]'}"/>
                                    <TextBox Width="200" Margin="8,0,0,0" Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Expander>

            <!-- TODO: Fix display so that indices are only listed once on the left, and replaced by rating strings, remove extraneous Exercise/Melee/Combat labels and line up columns with the QuadBase layout; remove Expander once item filtering is in place  -->
            <!-- TotalAssistsOnPlayerRating -->
            <Expander Header="Total Assists On Player Rating" IsExpanded="False" Margin="0,6,0,6">
                <StackPanel Margin="8"  Orientation="Horizontal">
                    <TextBlock FontWeight="Bold" Text="Exercise" Margin="4,2"/>
                    <ItemsControl ItemsSource="{Binding TotalAssistsOnPlayerRating.Exercise}" AlternationCount="1000">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="8,2">
                                    <TextBlock Width="40" Text="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}, StringFormat='[{0}]'}"/>
                                    <TextBox Width="200" Margin="8,0,0,0" Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock FontWeight="Bold" Text="Melee" Margin="4,8,4,2"/>
                    <ItemsControl ItemsSource="{Binding TotalAssistsOnPlayerRating.Melee}" AlternationCount="1000">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="8,2">
                                    <TextBlock Width="40" Text="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}, StringFormat='[{0}]'}"/>
                                    <TextBox Width="200" Margin="8,0,0,0" Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock FontWeight="Bold" Text="Combat" Margin="4,8,4,2"/>
                    <ItemsControl ItemsSource="{Binding TotalAssistsOnPlayerRating.Combat}" AlternationCount="1000">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="8,2">
                                    <TextBlock Width="40" Text="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}, StringFormat='[{0}]'}"/>
                                    <TextBox Width="200" Margin="8,0,0,0" Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Expander>

            <!-- TODO: Properly integrate below items -->
            <Expander Header="Total Full Kills On AI Rank" IsExpanded="False" Margin="0,6,0,6">
                <TextBlock Text="{Binding TotalFullKillsOnAIRank}" TextWrapping="Wrap"/>
            </Expander>

            <Expander Header="Total Shared Kills On AI Rank" IsExpanded="False" Margin="0,6,0,6">
                <TextBlock Text="{Binding TotalSharedKillsOnAIRank}" TextWrapping="Wrap"/>
            </Expander>

            <Expander Header="Total Assists On AI Rank" IsExpanded="False" Margin="0,6,0,6">
                <TextBlock Text="{Binding TotalAssistsOnAIRank}" TextWrapping="Wrap"/>
            </Expander>

            <Expander Header="Total Hidden Cargo Found" IsExpanded="False" Margin="0,6,0,6">
                <TextBlock Text="{Binding TotalHiddenCargoFound}" TextWrapping="Wrap"/>
            </Expander>

            <Expander Header="Total Laser Hit" IsExpanded="False" Margin="0,6,0,6">
                <TextBlock Text="{Binding TotalLaserHit}" TextWrapping="Wrap"/>
            </Expander>

            <Expander Header="Total Laser Fired" IsExpanded="False" Margin="0,6,0,6">
                <TextBlock Text="{Binding TotalLaserFired}" TextWrapping="Wrap"/>
            </Expander>

            <Expander Header="Total Warhead Hit" IsExpanded="False" Margin="0,6,0,6">
                <TextBlock Text="{Binding TotalWarheadHit}" TextWrapping="Wrap"/>
            </Expander>

            <Expander Header="Total Warhead Fired" IsExpanded="False" Margin="0,6,0,6">
                <TextBlock Text="{Binding TotalWarheadFired}" TextWrapping="Wrap"/>
            </Expander>

            <Expander Header="Total Craft Losses" IsExpanded="False" Margin="0,6,0,6">
                <TextBlock Text="{Binding TotalCraftLosses}" TextWrapping="Wrap"/>
            </Expander>

            <Expander Header="Total Losses From Collisions" IsExpanded="False" Margin="0,6,0,6">
                <TextBlock Text="{Binding TotalLossesFromCollisions}" TextWrapping="Wrap"/>
            </Expander>

            <Expander Header="Total Losses From Starships" IsExpanded="False" Margin="0,6,0,6">
                <TextBlock Text="{Binding TotalLossesFromStarships}" TextWrapping="Wrap"/>
            </Expander>

            <Expander Header="Total Losses From Mines" IsExpanded="False" Margin="0,6,0,6">
                <TextBlock Text="{Binding TotalLossesFromMines}" TextWrapping="Wrap"/>
            </Expander>

            <Expander Header="Total Losses From Player Rank" IsExpanded="False" Margin="0,6,0,6">
                <TextBlock Text="{Binding TotalLossesFromPlayerRank}" TextWrapping="Wrap"/>
            </Expander>

            <Expander Header="Total Losses From AI Rank" IsExpanded="False" Margin="0,6,0,6">
                <TextBlock Text="{Binding TotalLossesFromAIRank}" TextWrapping="Wrap"/>
            </Expander>
            
            <!-- More scalar / array items -->
            <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
                <ctrl:LabeledTextBox Label="Current Rank:"
                    Value="{Binding CurrentRank, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Metadata=""/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
                <ctrl:LabeledTextBox Label="Total Count Missions Flown:"
                    Value="{Binding TotalCountMissionsFlown, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Metadata=""/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
                <ctrl:LabeledTextBox Label="Rank String:"
                    Value="{Binding RankString, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Metadata=""/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
                <ctrl:LabeledTextBox Label="Debrief Mission Score:"
                    Value="{Binding DebriefMissionScore, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Metadata=""/>
            </StackPanel>

            <!-- TODO -->
            <!-- Debrief arrays -->
            <Expander Header="Debrief Full Kills On Player" IsExpanded="False" Margin="0,6,0,6">
                <ItemsControl ItemsSource="{Binding DebriefFullKillsOnPlayer}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="4">
                                <TextBlock Width="40" Text="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}, StringFormat='[{0}]'}"/>
                                <TextBox Width="200" Margin="8,0,0,0" Text="{Binding ., Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Expander>

            <Expander Header="Debrief Shared Kills On Player" IsExpanded="False" Margin="0,6,0,6">
                <ItemsControl ItemsSource="{Binding DebriefSharedKillsOnPlayer}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="4">
                                <TextBlock Width="40" Text="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}, StringFormat='[{0}]'}"/>
                                <TextBox Width="200" Margin="8,0,0,0" Text="{Binding ., Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Expander>

            <Expander Header="Debrief Full Kills On FG" IsExpanded="False" Margin="0,6,0,6">
                <ItemsControl ItemsSource="{Binding DebriefFullKillsOnFG}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="4">
                                <TextBlock Width="40" Text="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}, StringFormat='[{0}]'}"/>
                                <TextBox Width="200" Margin="8,0,0,0" Text="{Binding ., Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Expander>

            <Expander Header="Debrief Shared Kills On FG" IsExpanded="False" Margin="0,6,0,6">
                <ItemsControl ItemsSource="{Binding DebriefSharedKillsOnFG}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="4">
                                <TextBlock Width="40" Text="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}, StringFormat='[{0}]'}"/>
                                <TextBox Width="200" Margin="8,0,0,0" Text="{Binding ., Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Expander>

            <Expander Header="Debrief Full Kills By Player" IsExpanded="False" Margin="0,6,0,6">
                <ItemsControl ItemsSource="{Binding DebriefFullKillsByPlayer}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="4">
                                <TextBlock Width="40" Text="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}, StringFormat='[{0}]'}"/>
                                <TextBox Width="200" Margin="8,0,0,0" Text="{Binding ., Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Expander>

            <Expander Header="Debrief Shared Kills By Player" IsExpanded="False" Margin="0,6,0,6">
                <ItemsControl ItemsSource="{Binding DebriefSharedKillsByPlayer}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="4">
                                <TextBlock Width="40" Text="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}, StringFormat='[{0}]'}"/>
                                <TextBox Width="200" Margin="8,0,0,0" Text="{Binding ., Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Expander>

            <Expander Header="Debrief Full Kills By FG" IsExpanded="False" Margin="0,6,0,6">
                <ItemsControl ItemsSource="{Binding DebriefFullKillsByFG}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="4">
                                <TextBlock Width="40" Text="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}, StringFormat='[{0}]'}"/>
                                <TextBox Width="200" Margin="8,0,0,0" Text="{Binding ., Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Expander>

            <Expander Header="Debrief Shared Kills By FG" IsExpanded="False" Margin="0,6,0,6">
                <ItemsControl ItemsSource="{Binding DebriefSharedKillsByFG}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="4">
                                <TextBlock Width="40" Text="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}, StringFormat='[{0}]'}"/>
                                <TextBox Width="200" Margin="8,0,0,0" Text="{Binding ., Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Expander>

            <Expander Header="Debrief Melee AI Rank FG" IsExpanded="False" Margin="0,6,0,6">
                <ItemsControl ItemsSource="{Binding DebriefMeleeAIRankFG}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="4">
                                <TextBlock Width="40" Text="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}, StringFormat='[{0}]'}"/>
                                <TextBox Width="200" Margin="8,0,0,0" Text="{Binding ., Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Expander>
            
            <!-- Connected players and team results -->
            <Expander Header="Connected Players" IsExpanded="False" Margin="0,6,0,6">
                <ItemsControl ItemsSource="{Binding ConnectedPlayer}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" TextWrapping="Wrap"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Expander>

            <Expander Header="Debrief Team Result" IsExpanded="False" Margin="0,6,0,6">
                <ItemsControl ItemsSource="{Binding DebriefTeamResult}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" TextWrapping="Wrap"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Expander>

            <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
                <ctrl:LabeledTextBox Label="Last Selected Faction:"
                    Value="{Binding LastSelectedFaction, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Metadata=""/>
            </StackPanel>
            
        </StackPanel>
    </ScrollViewer>
</UserControl>
