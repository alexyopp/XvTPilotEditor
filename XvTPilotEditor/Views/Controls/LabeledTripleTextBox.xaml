<UserControl x:Class="XvTPilotEditor.Views.Controls.LabeledTripleTextBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:XvTPilotEditor.Views.Controls"
             mc:Ignorable="d"
             x:Name="Root"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <DataTemplate x:Key="ReadOnlyText">
            <TextBlock VerticalAlignment="Center" Text="{Binding}"/>
        </DataTemplate>

        <!-- Separate editable templates so each TextBox binds back to the corresponding DP on this UserControl -->
        <DataTemplate x:Key="EditableText1">
            <TextBox VerticalAlignment="Center"
             Text="{Binding Path=TextBox1Content, RelativeSource={RelativeSource AncestorType=local:LabeledTripleTextBox}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
        </DataTemplate>

        <DataTemplate x:Key="EditableText2">
            <TextBox VerticalAlignment="Center"
             Text="{Binding Path=TextBox2Content, RelativeSource={RelativeSource AncestorType=local:LabeledTripleTextBox}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
        </DataTemplate>

        <DataTemplate x:Key="EditableText3">
            <TextBox VerticalAlignment="Center"
             Text="{Binding Path=TextBox3Content, RelativeSource={RelativeSource AncestorType=local:LabeledTripleTextBox}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
        </DataTemplate>
    </UserControl.Resources>
        <Grid>
        <local:QuadBase
            Column0Content="{Binding Label, RelativeSource={RelativeSource AncestorType=UserControl}}"
            Column1Content="{Binding TextBox1Content, RelativeSource={RelativeSource AncestorType=UserControl}}"
            Column2Content="{Binding TextBox2Content, RelativeSource={RelativeSource AncestorType=UserControl}}"
            Column3Content="{Binding TextBox3Content, RelativeSource={RelativeSource AncestorType=UserControl}}"

            Column0ContentTemplate="{StaticResource ReadOnlyText}"
            Column1ContentTemplate="{StaticResource EditableText1}"
            Column2ContentTemplate="{StaticResource EditableText2}"
            Column3ContentTemplate="{StaticResource EditableText3}"/>
    </Grid>
</UserControl>
