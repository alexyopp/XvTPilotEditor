<UserControl x:Class="XvTPilotEditor.Views.Controls.MissionCategoryRecordView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:XvTPilotEditor.Views.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <local:LabeledTripleTextBox
            Label="{Binding Name}"
            TextBox1Content="{Binding Exercise,         Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            TextBox2Content="{Binding Melee,            Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            TextBox3Content="{Binding CombatEngagement, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
    </Grid>
</UserControl>
