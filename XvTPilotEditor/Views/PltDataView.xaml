                TextBox1Content="{Binding TotalKillsExercise, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                TextBox2Content="{Binding TotalKillsMelee, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                TextBox3Content="{Binding TotalKillsCombatEngagement, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- FriendlyKills -->
            <ctrl:LabeledTripleTextBox
                Label="Friendly Kills:"
                TextBox1Content="{Binding FriendlyKillsExercise, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                TextBox2Content="{Binding FriendlyKillsMelee, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                TextBox3Content="{Binding FriendlyKillsCombatEngagement, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- TODO: Consider spinning the QuadBase control into its own named control (like LabeledTripleTextBox?), highlight the Exercise/Melee/Combat header and Rating index of the selected textbox to improve usability, remove Expander once item filtering is in place  -->
            <!-- TotalFullKillsOnPlayerRating, TotalSharedKillsOnPlayerRating -->
            <Expander Header="Total Kills On Player Rating" IsExpanded="False">
                <ctrl:QuadBase>
                    <!-- Index column -->
                    <ctrl:QuadBase.Column0Content>
                        <StackPanel>
                            <ItemsControl ItemsSource="{Binding CombinedTotalKillsOnPlayerRatingExercise}" AlternationCount="1000">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Height="30">
                                            <TextBlock Width="120" VerticalAlignment="Center" FontWeight="Bold"
                                                     Text="{Binding (ItemsControl.AlternationIndex),
                                                                    RelativeSource={RelativeSource AncestorType=ContentPresenter},
                                                                    Converter={conv:UIntToPilotRatingConverter}}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ctrl:QuadBase.Column0Content>

                    <!-- Exercise column (Full + Shared) -->
                    <ctrl:QuadBase.Column1Content>
                        <StackPanel>
                            <ItemsControl ItemsSource="{Binding CombinedTotalKillsOnPlayerRatingExercise}" AlternationCount="1000">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Height="30">
                                            <ctrl:KillsTuple KillsValue="{Binding Full.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             SharedKillsValue="{Binding Shared.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
