<UserControl x:Class="XvTPilotEditor.Views.Pl2DataView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:XvTPilotEditor.Views"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
        <StackPanel Orientation="Vertical" VerticalAlignment="Top">

            <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
                <Label Content="Pilot Name:" VerticalAlignment="Center"/>
                <TextBox Text="{Binding PilotName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <!-- TODO: Fill out the Pl2DataView once PltDataView is set; is there any way to use the same control for the two sets of data, since they're identical up to a point? -->

            <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
                <Label Content="Last Selected Faction:" VerticalAlignment="Center"/>
                <TextBox Text="{Binding LastSelectedFaction, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
