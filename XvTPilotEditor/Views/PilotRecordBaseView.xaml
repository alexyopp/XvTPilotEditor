<UserControl x:Class="XvTPilotEditor.Views.PilotRecordBaseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:XvTPilotEditor.Views"
             xmlns:ctrl="clr-namespace:XvTPilotEditor.Views.Controls"
             xmlns:conv="clr-namespace:XvTPilotEditor.Converters"
             mc:Ignorable="d">
    <StackPanel Orientation="Vertical" VerticalAlignment="Top">

        <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
            <ctrl:LabeledTextBox Label="Pilot Name:"
                Value="{Binding PilotName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                Metadata=""/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
            <ctrl:LabeledTextBox Label="Total Score:"
                Value="{Binding TotalScore, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                Metadata=""/>
        </StackPanel>


        <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
            <ctrl:LabeledTextBox Label="Player ID:"
                Value="{Binding PlayerID, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                Metadata=""/>
        </StackPanel>


        <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
            <ctrl:LabeledTextBox Label="Continued / Reflown Mission:"
                Value="{Binding ContinuedOrReflownMission, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                Metadata=""/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
            <ctrl:LabeledTextBox Label="Is Hosting:"
                Value="{Binding IsHosting, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                Metadata=""/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
            <ctrl:LabeledTextBox Label="Num Human Players In Mission:"
                Value="{Binding NumHumanPlayersInMission, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                Metadata=""/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
            <ctrl:LabeledTextBox Label="Front Fly Mode:"
                Value="{Binding FrontFlyMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                Metadata=""/>
        </StackPanel>

        <Expander Header="Unknown0x26" IsExpanded="False" Margin="0,6,0,6">
            <ItemsControl ItemsSource="{Binding Unknown0x26.Values}" AlternationCount="1000">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="25,4">
                            <TextBlock Width="40" Text="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}, StringFormat='[{0}]'}"/>
                            <TextBox Width="75" Margin="8,0,0,0" Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Expander>

        <Expander Header="Unknown0x166" IsExpanded="False" Margin="0,6,0,6">
            <ItemsControl ItemsSource="{Binding Unknown0x166.Values}" AlternationCount="1000">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="25,4">
                            <TextBlock Width="40" Text="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}, StringFormat='[{0}]'}"/>
                            <TextBox Width="75" Margin="8,0,0,0" Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Expander>

        <Expander Header="Unknown0x186" IsExpanded="False" Margin="0,6,0,6">
            <ItemsControl ItemsSource="{Binding Unknown0x186.Values}" AlternationCount="1000">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="25,4">
                            <TextBlock Width="40" Text="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}, StringFormat='[{0}]'}"/>
                            <TextBox Width="75" Margin="8,0,0,0" Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Expander>

        <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
            <ctrl:LabeledTextBox Label="Promo Points:"
                Value="{Binding PromoPoints, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                Metadata=""/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
            <ctrl:LabeledTextBox Label="Worse Promo Points:"
                Value="{Binding WorsePromoPoints, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                Metadata=""/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
            <ctrl:LabeledTextBox Label="Rank Adjustment Applied:"
                Value="{Binding RankAdjustmentApplied, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                Metadata=""/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
            <ctrl:LabeledTextBox Label="Percent To Next Rank:"
                Value="{Binding PercentToNextRank, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                Metadata=""/>
        </StackPanel>

        <!-- TODO: Highlight the Exercise/Melee/Combat header and label of the selected textbox to improve usability -->
        <ctrl:ExerciseMeleeCombatHeader/>

        <ctrl:MissionCategoryRecordView Label="Total Category Score:"                   Data="{Binding TotalCategoryScore}"/>
        <ctrl:MissionCategoryRecordView Label="Number of Flown Non-Series:"             Data="{Binding NumFlownNonSeries}"/>
        <ctrl:MissionCategoryRecordView Label="Number of Flown Series:"                 Data="{Binding NumFlownSeries}"/>
        <ctrl:MissionCategoryRecordView Label="Total Kills:"                            Data="{Binding TotalKills}"/>
        <ctrl:MissionCategoryRecordView Label="Total Friendly Kills:"                   Data="{Binding FriendlyKills}"/>

        <!-- TODO: Consider spinning the QuadBase control into its own named control (like LabeledTripleTextBox?) -->
        <!-- TODO: Remove Expander once item filtering is in place -->
        <!-- TotalFullKillsOnPlayerRating, TotalSharedKillsOnPlayerRating -->
        <Expander Header="Total Kills On Player Rating" IsExpanded="False">
            <ctrl:QuadBase>
                <!-- Index column -->
                <ctrl:QuadBase.Column0Content>
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding CombinedTotalKillsOnPlayerRatingExercise}" AlternationCount="1000">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Height="30">
                                        <TextBlock Width="120" VerticalAlignment="Center" FontWeight="Bold"
                                                    Text="{Binding (ItemsControl.AlternationIndex),
                                                                RelativeSource={RelativeSource AncestorType=ContentPresenter},
                                                                Converter={conv:UIntToPilotRatingConverter}}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ctrl:QuadBase.Column0Content>

                <!-- Exercise column (Full + Shared) -->
                <ctrl:QuadBase.Column1Content>
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding CombinedTotalKillsOnPlayerRatingExercise}" AlternationCount="1000">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Height="30">
                                        <ctrl:KillsTuple KillsValue="{Binding Full.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            SharedKillsValue="{Binding Shared.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ctrl:QuadBase.Column1Content>

                <!-- Melee column (Full + Shared) -->
                <ctrl:QuadBase.Column2Content>
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding CombinedTotalKillsOnPlayerRatingMelee}" AlternationCount="1000">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Height="30">
                                        <ctrl:KillsTuple KillsValue="{Binding Full.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            SharedKillsValue="{Binding Shared.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ctrl:QuadBase.Column2Content>

                <!-- Combat column (Full + Shared) -->
                <ctrl:QuadBase.Column3Content>
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding CombinedTotalKillsOnPlayerRatingCombat}" AlternationCount="1000">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Height="30">
                                        <ctrl:KillsTuple KillsValue="{Binding Full.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            SharedKillsValue="{Binding Shared.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ctrl:QuadBase.Column3Content>
            </ctrl:QuadBase>
        </Expander>

        <ctrl:MissionCategoryRecordMatrixView   Label="Total Assists By Player Rating"          Data="{Binding TotalAssistsByPlayerRating}"     IndexConverter="{conv:UIntToPilotRatingConverter}"  />

        <!-- TODO: Consider spinning the QuadBase control into its own named control (like LabeledTripleTextBox?) -->
        <!-- TODO: Remove Expander once item filtering is in place -->
        <!-- TotalFullKillsOnAIRank, TotalSharedKillsOnAIRank -->
        <Expander Header="Total Kills On AI Rank" IsExpanded="False">
            <ctrl:QuadBase>
                <!-- Index column -->
                <ctrl:QuadBase.Column0Content>
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding CombinedTotalKillsOnAIRankExercise}" AlternationCount="1000">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Height="30">
                                        <TextBlock Width="120" VerticalAlignment="Center" FontWeight="Bold"
                                        Text="{Binding (ItemsControl.AlternationIndex),
                                                    RelativeSource={RelativeSource AncestorType=ContentPresenter},
                                                    Converter={conv:UIntToAIRankConverter}}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ctrl:QuadBase.Column0Content>

                <!-- Exercise column (Full + Shared) -->
                <ctrl:QuadBase.Column1Content>
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding CombinedTotalKillsOnAIRankExercise}" AlternationCount="1000">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Height="30">
                                        <ctrl:KillsTuple KillsValue="{Binding Full.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                SharedKillsValue="{Binding Shared.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ctrl:QuadBase.Column1Content>

                <!-- Melee column (Full + Shared) -->
                <ctrl:QuadBase.Column2Content>
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding CombinedTotalKillsOnAIRankMelee}" AlternationCount="1000">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Height="30">
                                        <ctrl:KillsTuple KillsValue="{Binding Full.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                SharedKillsValue="{Binding Shared.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ctrl:QuadBase.Column2Content>

                <!-- Combat column (Full + Shared) -->
                <ctrl:QuadBase.Column3Content>
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding CombinedTotalKillsOnAIRankCombat}" AlternationCount="1000">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Height="30">
                                        <ctrl:KillsTuple KillsValue="{Binding Full.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                SharedKillsValue="{Binding Shared.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ctrl:QuadBase.Column3Content>
            </ctrl:QuadBase>
        </Expander>

        <ctrl:MissionCategoryRecordMatrixView   Label="Total Assists By AI Rank"                Data="{Binding TotalAssistsByAIRank}"           IndexConverter="{conv:UIntToAIRankConverter}"       />
        <ctrl:MissionCategoryRecordView         Label="Total Hidden Cargo Found:"               Data="{Binding TotalHiddenCargoFound}"                                                              />
        <ctrl:MissionCategoryRecordView         Label="Total Lasers Hit:"                       Data="{Binding TotalLaserHit}"                                                                      />
        <ctrl:MissionCategoryRecordView         Label="Total Lasers Fired:"                     Data="{Binding TotalLaserFired}"                                                                    />
        <ctrl:MissionCategoryRecordView         Label="Total Warheads Hit:"                     Data="{Binding TotalWarheadHit}"                                                                    />
        <ctrl:MissionCategoryRecordView         Label="Total Warheads Fired:"                   Data="{Binding TotalWarheadFired}"                                                                  />
        <ctrl:MissionCategoryRecordView         Label="Total Craft Losses:"                     Data="{Binding TotalCraftLosses}"                                                                   />
        <ctrl:MissionCategoryRecordView         Label="Total Craft Losses From Collisions:"     Data="{Binding TotalLossesFromCollisions}"                                                          />
        <ctrl:MissionCategoryRecordView         Label="Total Craft Losses From Starships:"      Data="{Binding TotalLossesFromStarships}"                                                           />
        <ctrl:MissionCategoryRecordView         Label="Total Craft Losses From Mines:"          Data="{Binding TotalLossesFromMines}"                                                               />
        <ctrl:MissionCategoryRecordMatrixView   Label="Total Losses By Player Rating"           Data="{Binding TotalLossesByPlayerRating}"      IndexConverter="{conv:UIntToPilotRatingConverter}"  />
        <ctrl:MissionCategoryRecordMatrixView   Label="Total Losses By AI Rank"                 Data="{Binding TotalLossesByAIRank}"            IndexConverter="{conv:UIntToAIRankConverter}"       />

        <!-- TODO: Combine CurrentRank and RankString into a single control? -->
        <!-- Leave this number value as-is; do not convert to a Pilot Rating description -->
        <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
            <ctrl:LabeledTextBox Label="Current Rank:"
                Value="{Binding CurrentRank, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                Metadata=""/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
            <ctrl:LabeledTextBox Label="Total Count Missions Flown:"
                Value="{Binding TotalCountMissionsFlown, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                Metadata=""/>
        </StackPanel>

        <Expander Header="Rank Achieved On Mission #" IsExpanded="False" Margin="0,6,0,6">
            <ItemsControl ItemsSource="{Binding RankAchievedOnMissionCount.Values}" AlternationCount="1000">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="25,4">
                            <TextBlock Width="125" FontWeight="Bold" Text="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}, Converter={conv:UIntToPilotRatingConverter}}"/>
                            <TextBox Width="75" Margin="8,0,0,0" Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Expander>

        <!-- TODO: Combine CurrentRank and RankString into a single control? Remember EH uses different strings, so don't just use a dropdown populated by the vanilla rank strings -->
        <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
            <ctrl:LabeledTextBox Label="Rank String:"
                Value="{Binding RankString, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                Metadata=""/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
            <ctrl:LabeledTextBox Label="Debrief Mission Score:"
                Value="{Binding DebriefMissionScore, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                Metadata=""/>
        </StackPanel>

        <!-- DebriefFullKillsOnPlayer, DebriefSharedKillsOnPlayer -->
        <Expander Header="Debrief Kills On Player" IsExpanded="False" Margin="0,6,0,6">
            <ItemsControl ItemsSource="{Binding CombinedDebriefKillsOnPlayer}" AlternationCount="1000">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Width="40" Margin="25,4" Text="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}, StringFormat='[{0}]'}"/>
                            <ctrl:KillsTuple Grid.Column="1"
                                                KillsValue="{Binding Full.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                SharedKillsValue="{Binding Shared.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Expander>

        <!-- DebriefFullKillsOnFG, DebriefSharedKillsOnFG -->
        <Expander Header="Debrief Kills On Flight Group" IsExpanded="False" Margin="0,6,0,6">
            <ItemsControl ItemsSource="{Binding CombinedDebriefKillsOnFG}" AlternationCount="1000">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Width="40" Margin="25,4" Text="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}, StringFormat='[{0}]'}"/>
                            <ctrl:KillsTuple Grid.Column="1"
                                                KillsValue="{Binding Full.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                SharedKillsValue="{Binding Shared.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Expander>

        <!-- DebriefFullKillsByPlayer, DebriefSharedKillsByPlayer -->
        <Expander Header="Debrief Kills By Player" IsExpanded="False" Margin="0,6,0,6">
            <ItemsControl ItemsSource="{Binding CombinedDebriefKillsByPlayer}" AlternationCount="1000">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Width="40" Margin="25,4" Text="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}, StringFormat='[{0}]'}"/>
                            <ctrl:KillsTuple Grid.Column="1"
                                    KillsValue="{Binding Full.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    SharedKillsValue="{Binding Shared.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Expander>

        <!-- DebriefFullKillsByFG, DebriefSharedKillsByFG -->
        <Expander Header="Debrief Kills By Flight Group" IsExpanded="False" Margin="0,6,0,6">
            <ItemsControl ItemsSource="{Binding CombinedDebriefKillsByFG}" AlternationCount="1000">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Width="40" Margin="25,4" Text="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}, StringFormat='[{0}]'}"/>
                            <ctrl:KillsTuple Grid.Column="1"
                                    KillsValue="{Binding Full.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    SharedKillsValue="{Binding Shared.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Expander>

        <!-- TODO: Find out what this means -->
        <Expander Header="Debrief Melee AI Rank FG" IsExpanded="False" Margin="0,6,0,6">
            <ItemsControl ItemsSource="{Binding DebriefMeleeAIRankFG.Values}" AlternationCount="1000">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="25,4">
                            <TextBlock Width="40" Text="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}, StringFormat='[{0}]'}"/>
                            <TextBox Width="75" Margin="8,0,0,0" Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Expander>

        <Expander Header="Connected Players" IsExpanded="False" Margin="0,6,0,6">
            <ItemsControl ItemsSource="{Binding ConnectedPlayer}" AlternationCount="1000">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Width="20" Text="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}, StringFormat='[{0}]'}"/>
                            <ctrl:ConnectedPlayerRecordView Margin="0,0,20,0"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Expander>

        <Expander Header="Debrief Team Results" IsExpanded="False" Margin="0,6,0,6">
            <ItemsControl ItemsSource="{Binding DebriefTeamResult}" AlternationCount="1000">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Width="20" Text="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}, StringFormat='[{0}]'}"/>
                            <ctrl:TeamResultRecordView Margin="0,0,20,0"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Expander>

    </StackPanel>
</UserControl>
