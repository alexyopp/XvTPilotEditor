<UserControl x:Class="XvTPilotEditor.Views.Controls.TournamentTeamRecordView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:XvTPilotEditor.Views.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- TODO: What does this mean? -->
        <local:LabeledTextBox Label="Team Participation State:"
                              Value="{Binding TeamParticipationState, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Metadata=""
                              Grid.Row="0"/>

        <local:LabeledTextBox Label="Total Team Score:"
                              Value="{Binding TotalTeamScore, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Metadata=""
                              Grid.Row="1"/>

        <local:LabeledTextBox Label="Number Of 1st Places:"
                              Value="{Binding NumberOfMeleeRankingsFirst, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Metadata=""
                              Grid.Row="2"/>

        <local:LabeledTextBox Label="Number Of 2nd Places:"
                              Value="{Binding NumberOfMeleeRankingsSecond, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Metadata=""
                              Grid.Row="3"/>

        <local:LabeledTextBox Label="Number Of 3rd Places:"
                              Value="{Binding NumberOfMeleeRankingsThird, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Metadata=""
                              Grid.Row="4"/>

    </Grid>
</UserControl>
