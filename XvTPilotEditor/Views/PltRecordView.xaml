        <!-- TODO: Confirm label is correct -->
        <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
            <ctrl:LabeledTextBox Label="Number of Sorties In Last Battle:"
                                 Value="{Binding NumCombatFlownInLastBattle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Metadata=""/>
        </StackPanel>

