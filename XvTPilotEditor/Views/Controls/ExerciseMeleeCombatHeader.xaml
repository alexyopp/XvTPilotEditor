<UserControl x:Class="XvTPilotEditor.Views.Controls.ExerciseMeleeCombatHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:XvTPilotEditor.Views.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="175"/>
            <ColumnDefinition Width="175"/>
            <ColumnDefinition Width="175"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="1" HorizontalAlignment="Center" Text="Exercise" FontSize="16" FontWeight="Bold" Margin="5"/>
        <TextBlock Grid.Column="2" HorizontalAlignment="Center" Text="Melee" FontSize="16" FontWeight="Bold" Margin="5"/>
        <TextBlock Grid.Column="3" HorizontalAlignment="Center" Text="Combat" FontSize="16" FontWeight="Bold" Margin="5"/>
    </Grid>
</UserControl>
