<UserControl x:Class="XvTPilotEditor.Views.Controls.ExerciseMeleeCombatHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:XvTPilotEditor.Views.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <DataTemplate x:Key="HeaderTextTemplate">
            <TextBlock HorizontalAlignment="Center" FontSize="16" FontWeight="Bold" Margin="5" Text="{Binding}"/>
        </DataTemplate>
    </UserControl.Resources>
    <Grid>
        <local:QuadBase
            Column1Content="Exercise"
            Column2Content="Melee"
            Column3Content="Combat"

            Column1ContentTemplate="{StaticResource HeaderTextTemplate}"
            Column2ContentTemplate="{StaticResource HeaderTextTemplate}"
            Column3ContentTemplate="{StaticResource HeaderTextTemplate}"/>
    </Grid>
</UserControl>
