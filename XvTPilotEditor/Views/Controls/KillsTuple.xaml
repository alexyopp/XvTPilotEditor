<UserControl x:Class="XvTPilotEditor.Views.Controls.KillsTuple"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Height="30">
        <TextBox Height="20" Width="75" Text="{Binding KillsValue, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
        <TextBlock Text="(" FontSize="18" Margin="10,0,0,0"/>
        <TextBox Height="20" Width="75" Text="{Binding SharedKillsValue, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
        <TextBlock Text=")" FontSize="18"/>
    </StackPanel>
</UserControl>
