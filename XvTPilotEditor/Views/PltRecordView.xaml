        <ctrl:ExerciseMeleeCombatHeader/>

        <!-- TODO: What is this? -->
        <!-- UnknownRecord1 -->
        <ctrl:LabeledTripleTextBox
            Label="UnknownRecord1:"
            TextBox1Content="{Binding UnknownRecord1Exercise, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            TextBox2Content="{Binding UnknownRecord1Melee, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            TextBox3Content="{Binding UnknownRecord1CombatEngagement, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

