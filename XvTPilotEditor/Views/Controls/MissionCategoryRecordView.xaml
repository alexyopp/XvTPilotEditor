<UserControl x:Class="XvTPilotEditor.Views.Controls.MissionCategoryRecordView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:XvTPilotEditor.Views.Controls"
             mc:Ignorable="d" 
             x:Name="Root"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <local:LabeledTripleTextBox
            Label="{Binding Label, ElementName=Root}"
            TextBox1Content="{Binding Data.Exercise,         Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ElementName=Root}"
            TextBox2Content="{Binding Data.Melee,            Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ElementName=Root}"
            TextBox3Content="{Binding Data.CombatEngagement, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ElementName=Root}"/>
    </Grid>
</UserControl>
