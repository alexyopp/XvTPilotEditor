<UserControl x:Class="XvTPilotEditor.Views.PltDataView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:XvTPilotEditor.Views"
             xmlns:ctrl="clr-namespace:XvTPilotEditor.Views.Controls"
             xmlns:conv="clr-namespace:XvTPilotEditor.Converters"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
        <StackPanel Orientation="Vertical" VerticalAlignment="Top">

            <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
                <ctrl:LabeledTextBox Label="Pilot Name:"
                    Value="{Binding PilotName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Metadata=""/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
                <ctrl:LabeledTextBox Label="Total Score:"
                    Value="{Binding TotalScore, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Metadata=""/>
            </StackPanel>
            

            <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
                <ctrl:LabeledTextBox Label="Player ID:"
                    Value="{Binding PlayerID, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Metadata=""/>
            </StackPanel>


            <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
                <ctrl:LabeledTextBox Label="Continued / Reflown Mission:"
                    Value="{Binding ContinuedOrReflownMission, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Metadata=""/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
                <ctrl:LabeledTextBox Label="Is Hosting:"
                    Value="{Binding IsHosting, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Metadata=""/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
                <ctrl:LabeledTextBox Label="Num Human Players In Mission:"
                    Value="{Binding NumHumanPlayersInMission, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Metadata=""/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
                <ctrl:LabeledTextBox Label="Front Fly Mode:"
                    Value="{Binding FrontFlyMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Metadata=""/>
            </StackPanel>

            <!-- Arrays as expanders (simple indexed list) -->
            <Expander Header="Unknown0x26" IsExpanded="False" Margin="0,6,0,6">
                <ItemsControl ItemsSource="{Binding Unknown0x26.Values}" AlternationCount="1000">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="25,4">
                                <TextBlock Width="40" Text="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}, StringFormat='[{0}]'}"/>
                                <TextBox Width="75" Margin="8,0,0,0" Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Expander>

            <Expander Header="Unknown0x166" IsExpanded="False" Margin="0,6,0,6">
                <ItemsControl ItemsSource="{Binding Unknown0x166.Values}" AlternationCount="1000">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="25,4">
                                <TextBlock Width="40" Text="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}, StringFormat='[{0}]'}"/>
                                <TextBox Width="75" Margin="8,0,0,0" Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Expander>

            <Expander Header="Unknown0x186" IsExpanded="False" Margin="0,6,0,6">
                <ItemsControl ItemsSource="{Binding Unknown0x186.Values}" AlternationCount="1000">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="25,4">
                                <TextBlock Width="40" Text="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}, StringFormat='[{0}]'}"/>
                                <TextBox Width="75" Margin="8,0,0,0" Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Expander>

            <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
                <ctrl:LabeledTextBox Label="Promo Points:"
                    Value="{Binding PromoPoints, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Metadata=""/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
                <ctrl:LabeledTextBox Label="Worse Promo Points:"
                    Value="{Binding WorsePromoPoints, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Metadata=""/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
                <ctrl:LabeledTextBox Label="Rank Adjustment Applied:"
                    Value="{Binding RankAdjustmentApplied, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Metadata=""/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
                <ctrl:LabeledTextBox Label="Percent To Next Rank:"
                    Value="{Binding PercentToNextRank, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Metadata=""/>
            </StackPanel>
            
            <ctrl:ExerciseMeleeCombatHeader/>

            <!-- TotalCategoryScore -->
            <ctrl:LabeledTripleTextBox
                Label="Total Category Score:"
                TextBox1Content="{Binding TotalCategoryScoreExercise, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                TextBox2Content="{Binding TotalCategoryScoreMelee, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                TextBox3Content="{Binding TotalCategoryScoreCombatEngagement, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

