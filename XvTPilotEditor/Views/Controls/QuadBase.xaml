<UserControl x:Class="XvTPilotEditor.Views.Controls.QuadBase"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="175"/>
            <ColumnDefinition Width="225"/>
            <ColumnDefinition Width="225"/>
            <ColumnDefinition Width="225"/>
        </Grid.ColumnDefinitions>

        <ContentPresenter Grid.Column="0" Content="{Binding Column0Content, ElementName=Root}" ContentTemplate="{Binding Column0ContentTemplate, ElementName=Root}"/>
        <ContentPresenter Grid.Column="1" Content="{Binding Column1Content, ElementName=Root}" ContentTemplate="{Binding Column1ContentTemplate, ElementName=Root}"/>
        <ContentPresenter Grid.Column="2" Content="{Binding Column2Content, ElementName=Root}" ContentTemplate="{Binding Column2ContentTemplate, ElementName=Root}"/>
        <ContentPresenter Grid.Column="3" Content="{Binding Column3Content, ElementName=Root}" ContentTemplate="{Binding Column3ContentTemplate, ElementName=Root}"/>
    </Grid>
</UserControl>
