<UserControl x:Class="XvTPilotEditor.Views.Controls.TeamResultRecordView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:XvTPilotEditor.Views.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="300">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <local:LabeledTextBox Label="Total Mission Score:"
                              Value="{Binding TotalMissionScore, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Metadata=""
                              Grid.Row="0"/>

        <local:LabeledTextBox Label="Is Mission Complete:"
                              Value="{Binding IsMissionComplete, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Metadata=""
                              Grid.Row="1"/>

        <local:LabeledTextBox Label="Unknown0x8:"
                              Value="{Binding Unknown0x8, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Metadata=""
                              Grid.Row="2"/>

        <!-- TODO: Confirm time is in seconds, does it have a value even if mission doesn't succeed? -->
        <local:LabeledTextBox Label="Mission Duration (in seconds):"
                              Value="{Binding TimeMissionComplete, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Metadata=""
                              Grid.Row="3"/>
        
        <Grid Grid.Row="4" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Kills (Shared Kills): "/>
            <local:KillsTuple Grid.Column="1"
                              HorizontalAlignment="Right"
                              KillsValue="{Binding FullKills, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              SharedKillsValue="{Binding SharedKills, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
        </Grid>

        <local:LabeledTextBox Label="Losses:"
                              Value="{Binding Losses, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Metadata=""
                              Grid.Row="5"/>
    </Grid>
</UserControl>
